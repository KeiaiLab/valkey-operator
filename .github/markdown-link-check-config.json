{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://localhost"
    },
    {
      "pattern": "^https://github\\.com/keiailab/valkey-operator/pull/"
    },
    {
      "pattern": "^https://github\\.com/keiailab/valkey-operator/issues/"
